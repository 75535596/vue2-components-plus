{
  "name": "vue2-components-plus",
  "version": "1.0.28",
  "private": false,
  "type": "module",
  "main": "./dist/vue2-components-plus.umd.cjs",
  "module": "./dist/vue2-components-plus.js",
  "style": "./dist/vue2-components-plus.css",
  "exports": {
    "./dist/vue2-components-plus.css": "./dist/vue2-components-plus.css",
    "./css": "./dist/vue2-components-plus.css",
    ".": {
      "import": "./dist/vue2-components-plus.js",
      "require": "./dist/vue2-components-plus.umd.cjs",
      "default": "./dist/vue2-components-plus.js"
    },
    "./legacy": {
      "import": "./legacy.js",
      "require": "./legacy.js",
      "default": "./legacy.js"
    },
    "./style.css": "./dist/vue2-components-plus.css"
  },
  "sideEffects": [
    "*.css",
    "./dist/style.css"
  ],
  "files": [
    "dist",
    "legacy.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:es5": "pnpm build && babel dist/vue2-components-plus.js --out-file dist/vue2-components-plus.es5.js --config-file ./babel.es5.config.cjs",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "element-ui": "^2.15.14",
    "vue": "2.7.16"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.7",
    "@babel/core": "^7.25.7",
    "@babel/preset-env": "^7.25.7",
    "@vitejs/plugin-vue2": "^2.3.3",
    "element-ui": "^2.15.14",
    "rollup-plugin-copy": "^3.5.0",
    "terser": "^5.30.3",
    "vite": "^4.5.14",
    "vue": "2.7.16",
    "vue-template-compiler": "2.7.16"
  },
  "dependencies": {
  }
}
